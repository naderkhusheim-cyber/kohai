{
  "name": "kohai",
  "version": "0.1.0",
  "description": "Your anime kohai who lives next to your terminal and reacts to your Claude Code session.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prepare-engine": "node scripts/prepare-engine.js",
    "build": "npm run prepare-engine && electron-builder --mac dmg",
    "setup-claude": "node scripts/setup-claude.js",
    "install-hooks": "node plugins/kohai/hooks/install.js",
    "uninstall-hooks": "node plugins/kohai/hooks/uninstall.js",
    "install-command": "node scripts/install-command.js"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.2",
    "@pixiv/three-vrm-animation": "^3.5.2",
    "express": "^4.21.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.kohai.app",
    "productName": "Kohai",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "prompt-reactor.js",
      "renderer/**/*",
      "hooks/**/*",
      "assets/**/*",
      "scripts/**/*",
      "slash-commands/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/voicevox-engine",
        "to": "voicevox-engine",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
